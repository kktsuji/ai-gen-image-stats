#!/usr/bin/env sh
set -e

VENV_ACTIVATE="$(dirname -- "$0")/../venv/bin/activate"
if [ ! -f "$VENV_ACTIVATE" ]; then
  echo "Error: virtual environment not found at $VENV_ACTIVATE" >&2
  echo "Run: python -m venv venv && pip install -r requirements-dev.txt" >&2
  exit 1
fi
. "$VENV_ACTIVATE"
ruff check .                                    # lint
ruff format --check .                           # format check
pyright                                         # type check
npx --no-install prettier --check "**/*.md"     # Markdown format check
